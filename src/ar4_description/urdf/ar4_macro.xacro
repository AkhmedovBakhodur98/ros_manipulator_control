<?xml version="1.0" encoding="utf-8"?>
<!-- AR4 Robot Arm Macro
     Defines the 6-DOF AR4 robotic arm with all links and joints.

     Joint Configuration (from AR4 MK3 reference):
     J1: revolute, -170 to 170 deg, 60 deg/s
     J2: revolute, -42 to 90 deg, 60 deg/s
     J3: revolute, -89 to 52 deg, 60 deg/s
     J4: revolute, -165 to 165 deg, 60 deg/s
     J5: revolute, -105 to 105 deg, 60 deg/s
     J6: revolute, -155 to 155 deg, 60 deg/s
-->
<robot xmlns:xacro="http://wiki.ros.org/xacro">

  <!-- Joint limits (radians) - AR4 MK3 configuration -->
  <xacro:property name="j1_limit_min" value="${radians(-170)}"/>
  <xacro:property name="j1_limit_max" value="${radians(170)}"/>
  <xacro:property name="j2_limit_min" value="${radians(-42)}"/>
  <xacro:property name="j2_limit_max" value="${radians(90)}"/>
  <xacro:property name="j3_limit_min" value="${radians(-89)}"/>
  <xacro:property name="j3_limit_max" value="${radians(52)}"/>
  <xacro:property name="j4_limit_min" value="${radians(-165)}"/>
  <xacro:property name="j4_limit_max" value="${radians(165)}"/>
  <xacro:property name="j5_limit_min" value="${radians(-105)}"/>
  <xacro:property name="j5_limit_max" value="${radians(105)}"/>
  <xacro:property name="j6_limit_min" value="${radians(-155)}"/>
  <xacro:property name="j6_limit_max" value="${radians(155)}"/>

  <!-- Common properties -->
  <xacro:property name="joint_velocity" value="1.0472"/> <!-- ~60 deg/s -->
  <xacro:property name="joint_effort" value="1000"/>
  <xacro:property name="l6_length" value="0.03625"/>

  <!-- Material definitions -->
  <material name="ar4_yellow">
    <color rgba="1.0 0.843 0.0 1.0"/>
  </material>
  <material name="ar4_dark">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>

  <!-- AR4 Robot Macro -->
  <xacro:macro name="ar4_robot" params="tf_prefix parent *origin">

    <!-- Base joint connecting to parent -->
    <joint name="${tf_prefix}base_joint" type="fixed">
      <xacro:insert_block name="origin"/>
      <parent link="${parent}"/>
      <child link="${tf_prefix}base_link"/>
    </joint>

    <!-- Base Link -->
    <link name="${tf_prefix}base_link">
      <inertial>
        <origin rpy="0 0 0" xyz="-4.6941E-06 0.054174 0.038824"/>
        <mass value="0.7102"/>
        <inertia ixx="0.0039943" ixy="3.697E-07" ixz="-5.7364E-08"
                 iyy="0.0014946" iyz="-0.00036051" izz="0.0042554"/>
      </inertial>
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find ar4_description)/meshes/visual/base_link.STL"/>
        </geometry>
        <material name="ar4_yellow"/>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find ar4_description)/meshes/collision/base_link.STL"/>
        </geometry>
      </collision>
    </link>

    <!-- Link 1 -->
    <link name="${tf_prefix}link1">
      <inertial>
        <origin rpy="0 0 0" xyz="-0.022706 0.04294 -0.12205"/>
        <mass value="0.88065"/>
        <inertia ixx="0.0034" ixy="0.00042296" ixz="-0.00089231"
                 iyy="0.0041778" iyz="0.0010848" izz="0.0027077"/>
      </inertial>
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find ar4_description)/meshes/visual/link_1.STL"/>
        </geometry>
        <material name="ar4_yellow"/>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find ar4_description)/meshes/collision/link_1.STL"/>
        </geometry>
      </collision>
    </link>

    <!-- Joint 1 (J1) -->
    <joint name="${tf_prefix}J1" type="revolute">
      <origin rpy="${pi} 0 0" xyz="0 0 0"/>
      <parent link="${tf_prefix}base_link"/>
      <child link="${tf_prefix}link1"/>
      <axis xyz="0 0 1"/>
      <limit lower="${j1_limit_min}" upper="${j1_limit_max}"
             effort="${joint_effort}" velocity="${joint_velocity}"/>
      <dynamics damping="100.0" friction="10.0"/>
    </joint>

    <!-- Link 2 -->
    <link name="${tf_prefix}link2">
      <inertial>
        <origin rpy="0 0 0" xyz="0.064818 -0.11189 -0.038671"/>
        <mass value="0.57738"/>
        <inertia ixx="0.0047312" ixy="0.0022624" ixz="0.00032144"
                 iyy="0.0020836" iyz="-0.00056569" izz="0.0056129"/>
      </inertial>
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find ar4_description)/meshes/visual/link_2.STL"/>
        </geometry>
        <material name="ar4_yellow"/>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find ar4_description)/meshes/collision/link_2.STL"/>
        </geometry>
      </collision>
    </link>

    <!-- Joint 2 (J2) -->
    <joint name="${tf_prefix}J2" type="revolute">
      <origin rpy="1.5708 0 -1.5708" xyz="0 0.0642 -0.16977"/>
      <parent link="${tf_prefix}link1"/>
      <child link="${tf_prefix}link2"/>
      <axis xyz="0 0 -1"/>
      <limit lower="${j2_limit_min}" upper="${j2_limit_max}"
             effort="${joint_effort}" velocity="${joint_velocity}"/>
      <dynamics damping="100.0" friction="10.0"/>
    </joint>

    <!-- Link 3 -->
    <link name="${tf_prefix}link3">
      <inertial>
        <origin rpy="0 0 0" xyz="-0.00029765 -0.023661 -0.0019125"/>
        <mass value="0.1787"/>
        <inertia ixx="0.0001685" ixy="-2.7713E-05" ixz="5.6885E-06"
                 iyy="0.00012865" iyz="2.9256E-05" izz="0.00020744"/>
      </inertial>
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find ar4_description)/meshes/visual/link_3.STL"/>
        </geometry>
        <material name="ar4_yellow"/>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find ar4_description)/meshes/collision/link_3.STL"/>
        </geometry>
      </collision>
    </link>

    <!-- Joint 3 (J3) -->
    <joint name="${tf_prefix}J3" type="revolute">
      <origin rpy="0 0 3.1416" xyz="0 -0.305 0.007"/>
      <parent link="${tf_prefix}link2"/>
      <child link="${tf_prefix}link3"/>
      <axis xyz="0 0 -1"/>
      <limit lower="${j3_limit_min}" upper="${j3_limit_max}"
             effort="${joint_effort}" velocity="${joint_velocity}"/>
      <dynamics damping="100.0" friction="10.0"/>
    </joint>

    <!-- Link 4 -->
    <link name="${tf_prefix}link4">
      <inertial>
        <origin rpy="0 0 0" xyz="-0.0016798 -0.00057319 -0.074404"/>
        <mass value="0.34936"/>
        <inertia ixx="0.0030532" ixy="-1.8615E-05" ixz="-7.0047E-05"
                 iyy="0.0031033" iyz="-2.3301E-05" izz="0.00022264"/>
      </inertial>
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find ar4_description)/meshes/visual/link_4.STL"/>
        </geometry>
        <material name="ar4_yellow"/>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find ar4_description)/meshes/collision/link_4.STL"/>
        </geometry>
      </collision>
    </link>

    <!-- Joint 4 (J4) -->
    <joint name="${tf_prefix}J4" type="revolute">
      <origin rpy="1.5708 0 -1.5708" xyz="0 0 0.0"/>
      <parent link="${tf_prefix}link3"/>
      <child link="${tf_prefix}link4"/>
      <axis xyz="0 0 -1"/>
      <limit lower="${j4_limit_min}" upper="${j4_limit_max}"
             effort="${joint_effort}" velocity="${joint_velocity}"/>
      <dynamics damping="100.0" friction="10.0"/>
    </joint>

    <!-- Link 5 -->
    <link name="${tf_prefix}link5">
      <inertial>
        <origin rpy="0 0 0" xyz="0.0015066 -1.3102E-05 -0.012585"/>
        <mass value="0.11562"/>
        <inertia ixx="5.5035E-05" ixy="-1.019E-08" ixz="-2.6243E-06"
                 iyy="8.2921E-05" iyz="1.4437E-08" izz="5.2518E-05"/>
      </inertial>
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find ar4_description)/meshes/visual/link_5.STL"/>
        </geometry>
        <material name="ar4_yellow"/>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find ar4_description)/meshes/collision/link_5.STL"/>
        </geometry>
      </collision>
    </link>

    <!-- Joint 5 (J5) -->
    <joint name="${tf_prefix}J5" type="revolute">
      <origin rpy="${pi} 0 -1.5708" xyz="0 0 -0.22263"/>
      <parent link="${tf_prefix}link4"/>
      <child link="${tf_prefix}link5"/>
      <axis xyz="1 0 0"/>
      <limit lower="${j5_limit_min}" upper="${j5_limit_max}"
             effort="${joint_effort}" velocity="${joint_velocity}"/>
      <dynamics damping="100.0" friction="10.0"/>
    </joint>

    <!-- Link 6 -->
    <link name="${tf_prefix}link6">
      <inertial>
        <origin rpy="0 0 0" xyz="2.9287E-10 -1.6472E-09 0.0091432"/>
        <mass value="0.013863"/>
        <inertia ixx="1.3596E-06" ixy="3.0585E-13" ixz="5.7102E-14"
                 iyy="1.7157E-06" iyz="6.3369E-09" izz="2.4332E-06"/>
      </inertial>
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find ar4_description)/meshes/visual/link_6.STL"/>
        </geometry>
        <material name="ar4_yellow"/>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find ar4_description)/meshes/collision/link_6.STL"/>
        </geometry>
      </collision>
    </link>

    <!-- Joint 6 (J6) -->
    <joint name="${tf_prefix}J6" type="revolute">
      <origin rpy="0 0 3.1416" xyz="0.000 0 ${l6_length}"/>
      <parent link="${tf_prefix}link5"/>
      <child link="${tf_prefix}link6"/>
      <axis xyz="0 0 1"/>
      <limit lower="${j6_limit_min}" upper="${j6_limit_max}"
             effort="${joint_effort}" velocity="${joint_velocity}"/>
      <dynamics damping="100.0" friction="10.0"/>
    </joint>

    <!-- End Effector Link (mounting surface on link6) -->
    <link name="${tf_prefix}ee_link"/>
    <joint name="${tf_prefix}ee_joint" type="fixed">
      <parent link="${tf_prefix}link6"/>
      <child link="${tf_prefix}ee_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

  </xacro:macro>

</robot>
